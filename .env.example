# DBC Care / Hospital AI Assistant
# Copy to `.env` and fill in keys. Never commit `.env`.
# Conda env: hosmanag

# --- CLI text agent ---
GROQ_API_KEY=
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Cascade voice: Deepgram STT + DeepSeek LLM + Deepgram TTS ---
DEEPGRAM_API_KEY=
# Optional Owner/Admin key with billing:read (Admin balance display). Falls back to DEEPGRAM_API_KEY.
# DEEPGRAM_MANAGE_API_KEY=
# DEEPGRAM_VOICE=aura-2-thalia-en

# DeepSeek (Cascade LLM default)
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

GLM_API_KEY=
# GLM_MODEL=glm-4-flash
# GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# --- Realtime voice: OpenAI ---
OPENAI_API_KEY=
# OPENAI_REALTIME_MODEL=gpt-realtime
# OPENAI_REALTIME_VOICE=marin
# OPENAI_CHAT_MODEL=gpt-4o-mini

# --- Defaults (Admin UI can override via admin_settings.json) ---
# LLM_PROVIDER=deepseek
# BOT_MODE=cascade

# --- Admin login (defaults: Admin / 12345) ---
# ADMIN_USER=Admin
# ADMIN_PASS=12345
# ADMIN_TOKEN_SECRET=change-me-in-production

# --- Optional Daily transport ---
# DAILY_API_KEY=
# DAILY_ROOM_URL=
